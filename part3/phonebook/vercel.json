{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "public/**"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/index.js" },
    { "src": "/info", "dest": "/index.js" },
    {
      "src": "/public/(.*)",
      "headers": { "cache-control": "s-maxage=31536000, immutable" },
      "dest": "/public/$1"
    },
    { "src": "/(.*)", "dest": "/index.js" }
  ]
}
